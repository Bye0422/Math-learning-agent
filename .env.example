QWEN_API_KEY=replace-with-your-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen3.7-plus
QWEN_OCR_MODEL=qwen-vl-ocr
QWEN_EMBEDDING_MODEL=text-embedding-v4

# Optional runtime overrides
USE_MINERU_FOR_PDF=true
MINERU_CMD=.venv/Scripts/mineru.exe
MINERU_BACKEND=pipeline
MINERU_METHOD=auto
MINERU_LANG=ch
MINERU_TIMEOUT_SECONDS=1800
MINERU_TEMP_DIR_NAME=mineru_runtime
MINERU_ENABLE_PAGE_BATCH=true
MINERU_PAGE_BATCH_SIZE=5
MINERU_TRY_OCR_WHEN_AUTO_FAILS=false
MINERU_ENABLE_CACHE=true
MINERU_CACHE_DIR_NAME=cache/mineru_markdown
MINERU_CACHE_SCHEMA_VERSION=v2

ENABLE_SQLITE_MEMORY=true
MEMORY_DB_PATH=data/memory.db
ENABLE_QUESTION_CHUNKING=true
QUESTION_CHUNK_MIN_MARKERS=2
QUESTION_CHUNK_MAX_CHARS=2500
ENABLE_VECTOR_CACHE=true
VECTOR_CACHE_DIR_NAME=cache/vector_store

ENABLE_WRONGBOOK=true
WRONGBOOK_DB_PATH=data/wrongbook.db
CARD_OUTPUT_DIR=data/cards
CARD_HTML_OUTPUT_DIR=data/card_html
WRONGBOOK_PDF_OUTPUT_DIR=data/wrongbook_exports
MATHJAX_CDN_URL=https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js
